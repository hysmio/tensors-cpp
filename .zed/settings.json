{
  "format_on_save": "on",
  "formatter": {
    "language_server": {
      "name": "clangd"
    }
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "clangd",
        "arguments": [
          "--background-index",
          "--clang-tidy",
          "--completion-style=detailed",
          "--function-arg-placeholders",
          "--header-insertion=iwyu",
          "--clang-tidy-checks=*"
        ]
      }
    }
  },
  "tasks": {
  },
  "file_types": {
  }
}
